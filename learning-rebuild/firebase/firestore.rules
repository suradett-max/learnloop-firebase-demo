rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function linkedToStudent(studentKey) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/students/$(studentKey)).data.linkedUids;
    }

    match /users/{uid} {
      allow read, create, update: if owns(uid);
      allow delete: if false;

      match /progress/{subjectCode} {
        allow read, create, update: if owns(uid);
        allow delete: if false;
      }

      match /attempts/{attemptId} {
        allow read, create: if owns(uid);
        allow update, delete: if false;
      }
    }

    match /studentIndex/{studentKey} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /students/{studentKey} {
      allow get: if linkedToStudent(studentKey);
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.studentKey == studentKey
        && request.resource.data.joinCode is string
        && request.auth.uid in request.resource.data.linkedUids;
      allow update: if signedIn()
        && request.resource.data.studentKey == studentKey
        && request.resource.data.joinCode == resource.data.joinCode
        && request.auth.uid in request.resource.data.linkedUids;
      allow delete: if false;

      match /progress/{subjectCode} {
        allow read: if linkedToStudent(studentKey);
        allow create, update: if linkedToStudent(studentKey)
          && request.resource.data.studentKey == studentKey;
        allow delete: if false;
      }

      match /attempts/{attemptId} {
        allow read: if linkedToStudent(studentKey);
        allow create: if linkedToStudent(studentKey)
          && request.resource.data.studentKey == studentKey;
        allow update, delete: if false;
      }
    }

    match /content/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
