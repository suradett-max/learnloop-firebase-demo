{
  "rules": {
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['uid','studentKey','state','lastChanged']) && newData.child('uid').val() === auth.uid"
      }
    },
    ".read": false,
    ".write": false
  }
}

